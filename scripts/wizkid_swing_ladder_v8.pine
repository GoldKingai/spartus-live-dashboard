// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © thework123456
// Consolidation Zone logic based on "Consolidation Zones - Live" by LonesomeTheBlue (MPL 2.0)
// RSI Divergence logic based on TradingView built-in RSI (MPL 2.0)

//@version=6
indicator("Wizkid Swing Ladder v8 (Pro Build: Entry Engine + Short Signals)", overlay = true,
     max_lines_count = 500, max_labels_count = 500, max_boxes_count = 100)

//===============================================================
// 1) CONTEXT – XAUUSD ONLY
//===============================================================
isGold = str.contains(syminfo.ticker, "XAU")
if not isGold
    label.new(bar_index, high, "⚠ Wizkid Ladder is designed for XAUUSD",
        style = label.style_label_down,
        textcolor = color.white,
        color = color.red)

//===============================================================
// 2) TREND & BASIC RSI
//===============================================================
grpTrend = "Trend & RSI"
emaLenHTF   = input.int(200, "Trend EMA Length", minval = 1, group=grpTrend)
useTrendEMA = input.bool(true, "Use EMA Trend Filter", group=grpTrend)
emaTrend    = ta.ema(close, emaLenHTF)
trendUp     = close > emaTrend
trendDown   = close < emaTrend
plot(emaTrend, "Trend EMA", color = color.new(color.orange, 40))

rsiLen       = input.int(14, "RSI Length", minval = 2, group=grpTrend)
rsi          = ta.rsi(close, rsiLen)

// Momentum EMA (fast vs slow for direction confirmation)
grpMom = "Momentum"
emaFastLen = input.int(9, "Fast EMA", minval = 2, group=grpMom)
emaSlowLen = input.int(21, "Slow EMA", minval = 5, group=grpMom)
emaFast    = ta.ema(close, emaFastLen)
emaSlow    = ta.ema(close, emaSlowLen)
momBull    = emaFast > emaSlow
momBear    = emaFast < emaSlow

//===============================================================
// 3) VISUAL TRENDLINES FROM PIVOTS (Wizkid style)
//===============================================================
grpTL = "Trendlines"
leftBarsTL  = input.int(10, "Trend Pivot Left Bars", minval = 1, group=grpTL)
rightBarsTL = input.int(10, "Trend Pivot Right Bars", minval = 1, group=grpTL)

ph = ta.pivothigh(high, leftBarsTL, rightBarsTL)
pl = ta.pivotlow(low,  leftBarsTL, rightBarsTL)

var float ph1Price = na
var float ph2Price = na
var int   ph1Bar   = na
var int   ph2Bar   = na

var float pl1Price = na
var float pl2Price = na
var int   pl1Bar   = na
var int   pl2Bar   = na

if not na(ph)
    ph2Price := ph1Price
    ph2Bar   := ph1Bar
    ph1Price := ph
    ph1Bar   := bar_index - rightBarsTL

if not na(pl)
    pl2Price := pl1Price
    pl2Bar   := pl1Bar
    pl1Price := pl
    pl1Bar   := bar_index - rightBarsTL

var line downTL = na
var line upTL   = na

if not na(ph1Price) and not na(ph2Price)
    if na(downTL)
        downTL := line.new(ph2Bar, ph2Price, ph1Bar, ph1Price,
            extend = extend.right, width = 1, color = color.new(color.red, 0))
    else
        line.set_xy1(downTL, ph2Bar, ph2Price)
        line.set_xy2(downTL, ph1Bar, ph1Price)

if not na(pl1Price) and not na(pl2Price)
    if na(upTL)
        upTL := line.new(pl2Bar, pl2Price, pl1Bar, pl1Price,
            extend = extend.right, width = 1, color = color.new(color.teal, 0))
    else
        line.set_xy1(upTL, pl2Bar, pl2Price)
        line.set_xy2(upTL, pl1Bar, pl1Price)

plotshape(not na(ph), title = "Swing High", style = shape.triangledown,
    location = location.abovebar, color = color.red, size = size.tiny, offset = -rightBarsTL)
plotshape(not na(pl), title = "Swing Low", style = shape.triangleup,
    location = location.belowbar, color = color.teal, size = size.tiny, offset = -rightBarsTL)

//===============================================================
// 4) POSITION-OPENING MODULE (Liquidity Sweep + BOS)
//    Supports BOTH long and short setups.
//===============================================================
grpPO = "Position Opening (Pro)"
poEnabled     = input.bool(true,  "Enable Position-Opening Logic", group=grpPO)
poShowLabels  = input.bool(true,  "Show PO Labels (SWEEP / BOS)", group=grpPO)
poShowZone    = input.bool(true,  "Show PO Zone Box", group=grpPO)

poATRLen     = input.int(14,  "ATR Length", minval=5, group=grpPO)
poSwingLen   = input.int(5,   "Swing Length", minval=2, group=grpPO)
poEqTolATR   = input.float(0.35, "Equal High/Low tolerance (x ATR)", step=0.05, group=grpPO,
                 tooltip="How close two swing highs/lows must be to count as 'equal'. Higher = more sweeps detected.")
poBOSLookback= input.int(20,  "BOS lookback bars", minval=5, group=grpPO,
                 tooltip="How many bars back to check for structure break. Lower = earlier signals.")
poSetupWindow = input.int(40,  "Setup window bars", minval=10, group=grpPO,
                 tooltip="How many bars the sweep+BOS combo stays valid for entry. Wider = more signals on trending days.")
poRetestBars = input.int(25,  "Retest zone window bars", minval=5, group=grpPO,
                 tooltip="How many bars the retest zone box stays visible.")

poUseHTF     = input.bool(true, "Use HTF Bias in PO", group=grpPO)
poHTFTF      = input.timeframe("240", "HTF timeframe", group=grpPO)
poHTFEMALen  = input.int(200, "HTF EMA length", minval=20, group=grpPO)

poAtr = ta.atr(poATRLen)

// pivots for equal highs/lows
poPH = ta.pivothigh(high, poSwingLen, poSwingLen)
poPL = ta.pivotlow(low,  poSwingLen, poSwingLen)

var float poLastPH = na
var float poPrevPH = na
var float poLastPL = na
var float poPrevPL = na

if not na(poPH)
    poPrevPH := poLastPH
    poLastPH := poPH

if not na(poPL)
    poPrevPL := poLastPL
    poLastPL := poPL

poEqHigh = not na(poLastPH) and not na(poPrevPH) and math.abs(poLastPH - poPrevPH) <= poAtr * poEqTolATR
poEqLow  = not na(poLastPL) and not na(poPrevPL) and math.abs(poLastPL - poPrevPL) <= poAtr * poEqTolATR

// Sweep: wick takes the level and closes back inside
poSweepDown = poEqLow  and not na(poPrevPL) and low < poPrevPL and close > poPrevPL
poSweepUp   = poEqHigh and not na(poPrevPH) and high > poPrevPH and close < poPrevPH

// BOS (reduced lookback for earlier detection)
poRecentHigh = ta.highest(high, poBOSLookback)
poRecentLow  = ta.lowest(low,  poBOSLookback)
poBosUp   = close > poRecentHigh[1]
poBosDown = close < poRecentLow[1]

// BOS confirmation: next bar must hold direction
poBosUpConfirmed   = poBosUp[1]   and close > open
poBosDownConfirmed = poBosDown[1] and close < open

// HTF bias
poHTFClose = request.security(syminfo.tickerid, poHTFTF, close)
poHTFEMA   = request.security(syminfo.tickerid, poHTFTF, ta.ema(close, poHTFEMALen))
poHTFBull  = poHTFClose > poHTFEMA
poHTFBear  = poHTFClose < poHTFEMA

// --- Track sweep events (timestamps for entry engine) ---
var int   poSweepDownBar = na
var int   poSweepUpBar   = na

if poSweepDown
    poSweepDownBar := bar_index
if poSweepUp
    poSweepUpBar := bar_index

sweepDownRecent = not na(poSweepDownBar) and (bar_index - poSweepDownBar) <= poSetupWindow
sweepUpRecent   = not na(poSweepUpBar)   and (bar_index - poSweepUpBar)   <= poSetupWindow

// --- Long setup zones (for retest visualization) ---
var int   poLongSetupBar  = na
var float poLongZoneLow   = na
var float poLongZoneHigh  = na

if poSweepDown
    poLongSetupBar := bar_index
    poLongZoneLow  := low
    poLongZoneHigh := high

// --- Short setup zones ---
var int   poShortSetupBar = na
var float poShortZoneLow  = na
var float poShortZoneHigh = na

if poSweepUp
    poShortSetupBar := bar_index
    poShortZoneLow  := low
    poShortZoneHigh := high

// Retest detection (price enters the zone)
poInLongZone  = not na(poLongZoneLow)  and low <= poLongZoneHigh and high >= poLongZoneLow
poInShortZone = not na(poShortZoneLow) and low <= poShortZoneHigh and high >= poShortZoneLow

poRetestLong  = not na(poLongSetupBar)  and (bar_index - poLongSetupBar)  <= poRetestBars and poInLongZone
poRetestShort = not na(poShortSetupBar) and (bar_index - poShortSetupBar) <= poRetestBars and poInShortZone

// Expire old zones
if not na(poLongSetupBar) and (bar_index - poLongSetupBar) > poRetestBars
    poLongSetupBar := na
    poLongZoneLow  := na
    poLongZoneHigh := na

if not na(poShortSetupBar) and (bar_index - poShortSetupBar) > poRetestBars
    poShortSetupBar := na
    poShortZoneLow  := na
    poShortZoneHigh := na

// Long zone box (visual)
var box poBoxLong = na
if poEnabled and poShowZone and poRetestLong and not na(poLongZoneLow) and not na(poLongZoneHigh)
    if na(poBoxLong)
        poBoxLong := box.new(left=bar_index, top=poLongZoneHigh, right=bar_index, bottom=poLongZoneLow,
            border_color=color.new(color.lime, 0), bgcolor=color.new(color.lime, 88))
    else
        box.set_right(poBoxLong, bar_index)
        box.set_top(poBoxLong, poLongZoneHigh)
        box.set_bottom(poBoxLong, poLongZoneLow)
else
    if not na(poBoxLong) and not poRetestLong
        poBoxLong := na

// Short zone box (visual)
var box poBoxShort = na
if poEnabled and poShowZone and poRetestShort and not na(poShortZoneLow) and not na(poShortZoneHigh)
    if na(poBoxShort)
        poBoxShort := box.new(left=bar_index, top=poShortZoneHigh, right=bar_index, bottom=poShortZoneLow,
            border_color=color.new(color.red, 0), bgcolor=color.new(color.red, 88))
    else
        box.set_right(poBoxShort, bar_index)
        box.set_top(poBoxShort, poShortZoneHigh)
        box.set_bottom(poBoxShort, poShortZoneLow)
else
    if not na(poBoxShort) and not poRetestShort
        poBoxShort := na

// PO structure labels (with cooldown to prevent stacking)
var int lastSweepDownLabelBar = na
var int lastSweepUpLabelBar   = na
var int lastBosUpLabelBar     = na
var int lastBosDownLabelBar   = na
poLabelCooldown = 5

if poEnabled and poShowLabels
    if poSweepDown and (na(lastSweepDownLabelBar) or (bar_index - lastSweepDownLabelBar) >= poLabelCooldown)
        lastSweepDownLabelBar := bar_index
        label.new(bar_index, low, "SWEEP ▼", style=label.style_label_up,
            color=color.new(color.lime, 0), textcolor=color.black, size=size.small)
    if poSweepUp and (na(lastSweepUpLabelBar) or (bar_index - lastSweepUpLabelBar) >= poLabelCooldown)
        lastSweepUpLabelBar := bar_index
        label.new(bar_index, high, "SWEEP ▲", style=label.style_label_down,
            color=color.new(color.red, 20), textcolor=color.white, size=size.small)
    if poBosUpConfirmed and (na(lastBosUpLabelBar) or (bar_index - lastBosUpLabelBar) >= poLabelCooldown)
        lastBosUpLabelBar := bar_index
        label.new(bar_index, low, "BOS ▲", style=label.style_label_up,
            color=color.new(color.teal, 0), textcolor=color.white, size=size.small)
    if poBosDownConfirmed and (na(lastBosDownLabelBar) or (bar_index - lastBosDownLabelBar) >= poLabelCooldown)
        lastBosDownLabelBar := bar_index
        label.new(bar_index, high, "BOS ▼", style=label.style_label_down,
            color=color.new(color.maroon, 0), textcolor=color.white, size=size.small)

//===============================================================
// 5) LADDER SYSTEM – RUNG & TP LINES
//===============================================================
groupLadder = "Ladder Levels"

useAutoAnchor   = input.bool(true,  "Use Auto Anchor", group=groupLadder)
manualAnchor    = input.float(1900.0, "Manual Anchor Price (if Auto OFF)", step = 0.1, group=groupLadder)
ladderStep      = input.float(10.0, "Ladder Step Size ($ between rungs)", step = 0.1, group=groupLadder)
ladderCount     = input.int(5, "Number of Ladder Rungs", minval = 1, maxval = 50, group=groupLadder)

showTPLevels    = input.bool(true, "Show TP Ladder Above Each Rung (for partial TP)", group=groupLadder)
tpMultiplier    = input.float(1.0, "TP Distance Multiplier (x Step)", step = 0.1, group=groupLadder)

leftAnchor  = input.int(15, "Anchor Pivot Left", minval = 1, group=groupLadder)
rightAnchor = input.int(15, "Anchor Pivot Right", minval = 1, group=groupLadder)

plAnchor = ta.pivotlow(low, leftAnchor, rightAnchor)

// --- Ladder Reset Zone (Pro) ---
resetEnabled   = input.bool(true,  "Reset ladder if base breaks", group=groupLadder)
resetSteps     = input.float(2.0,  "Reset floor distance (x Step)", step=0.5, group=groupLadder)
resetOnClose   = input.bool(true,  "Reset requires CLOSE below floor (safer)", group=groupLadder)
minReanchorGap = input.float(1.0,  "Ignore tiny new pivots (< x Step)", step=0.1, group=groupLadder)

var float anchorPrice = na
var float lastAnchorPrice = na
var bool  ladderBroken = false

resetFloor = not na(anchorPrice) ? anchorPrice - (ladderStep * resetSteps) : na
plot(resetEnabled ? resetFloor : na, "Reset Floor", color=color.new(color.red, 70), style=plot.style_line)

ladderBroken := false
if resetEnabled and not na(anchorPrice) and not na(resetFloor)
    ladderBroken := resetOnClose ? (close < resetFloor) : (low < resetFloor)

// Anchor assignment (stabilized)
if not useAutoAnchor
    anchorPrice := manualAnchor
else
    if ladderBroken
        if not na(plAnchor)
            anchorPrice := plAnchor
    else
        if na(anchorPrice)
            if not na(plAnchor)
                anchorPrice := plAnchor
        else
            if not na(plAnchor)
                significantLower = plAnchor < anchorPrice - (ladderStep * minReanchorGap)
                if significantLower
                    anchorPrice := plAnchor

// Anchor label
var label anchorLabel = na
if barstate.islast and not na(anchorPrice)
    if not na(anchorLabel)
        label.delete(anchorLabel)
    anchorLabel := label.new(bar_index, anchorPrice, "Anchor\n(Ladder Base)",
        style = label.style_label_left,
        textcolor = color.white,
        color = color.new(color.blue, 40))

// Lines + state
var line[] ladderLines   = array.new_line()
var line[] tpLines       = array.new_line()
var bool[] rungBuyFired  = array.new_bool()
var bool[] rungSellFired = array.new_bool()

f_init_structs() =>
    szL = array.size(ladderLines)
    if szL > 0
        for i = 0 to szL - 1
            line.delete(array.get(ladderLines, i))
    array.clear(ladderLines)
    for i = 0 to ladderCount - 1
        l = line.new(bar_index, na, bar_index, na,
            extend = extend.right, width = 1, color = color.new(color.green, 65))
        array.push(ladderLines, l)

    szT = array.size(tpLines)
    if szT > 0
        for i = 0 to szT - 1
            line.delete(array.get(tpLines, i))
    array.clear(tpLines)
    for i = 0 to ladderCount - 1
        lt = line.new(bar_index, na, bar_index, na,
            extend = extend.right, width = 1, color = color.new(color.yellow, 75))
        array.push(tpLines, lt)

    array.clear(rungBuyFired)
    array.clear(rungSellFired)
    for i = 0 to ladderCount - 1
        array.push(rungBuyFired,  false)
        array.push(rungSellFired, false)

// rebuild if needed
rebuildNeeded = false
if not na(anchorPrice)
    if ladderBroken
        rebuildNeeded := true
    else if array.size(ladderLines) != ladderCount or
       array.size(tpLines)     != ladderCount or
       array.size(rungBuyFired)  != ladderCount or
       array.size(rungSellFired) != ladderCount or
       na(lastAnchorPrice) or anchorPrice != lastAnchorPrice
        rebuildNeeded := true

if rebuildNeeded and not na(anchorPrice)
    lastAnchorPrice := anchorPrice
    f_init_structs()

// update lines
if not na(anchorPrice)
    for i = 0 to ladderCount - 1
        rungPrice = anchorPrice + ladderStep * i

        l = array.get(ladderLines, i)
        line.set_xy1(l, bar_index - 1, rungPrice)
        line.set_xy2(l, bar_index,     rungPrice)
        line.set_color(l, color.new(color.green, 60))

        lt = array.get(tpLines, i)
        if showTPLevels
            tpPrice = rungPrice + (ladderStep * tpMultiplier)
            line.set_xy1(lt, bar_index - 1, tpPrice)
            line.set_xy2(lt, bar_index,     tpPrice)
            line.set_color(lt, color.new(color.yellow, 50))
        else
            line.set_xy1(lt, bar_index - 1, na)
            line.set_xy2(lt, bar_index,     na)

//===============================================================
// 6) CONSOLIDATION ZONES (LonesomeTheBlue)
//===============================================================
groupCZ = "Consolidation Zones"

prd         = input.int(10,  "CZ: Lookback Period", minval = 2, maxval = 50,  group=groupCZ)
conslen     = input.int(5,   "CZ: Min Consolidation Length", minval = 2, maxval = 20, group=groupCZ)
paintcons   = input.bool(true, "CZ: Paint Consolidation Area", group=groupCZ)
zonecol     = input.color(color.new(color.blue, 70), "CZ: Zone Color", group=groupCZ)
useCZFilter = input.bool(false, "CZ: Block BUY/SELL inside Consolidation", group=groupCZ)

float hb_ = ta.highestbars(high, prd) == 0 ? high : na
float lb_ = ta.lowestbars(low,  prd) == 0 ? low  : na
var int   czDir = 0
float zz = na
float pp = na

czDir := not na(hb_) and na(lb_) ? 1 : not na(lb_) and na(hb_) ? -1 : czDir
if not na(hb_) and not na(lb_)
    zz := czDir == 1 ? hb_ : lb_
else
    zz := not na(hb_) ? hb_ : not na(lb_) ? lb_ : na

for x = 0 to 1000
    if na(close) or czDir != czDir[x]
        break
    if not na(zz[x])
        if na(pp)
            pp := zz[x]
        else
            if czDir[x] == 1 and zz[x] > pp
                pp := zz[x]
            if czDir[x] == -1 and zz[x] < pp
                pp := zz[x]

var int   conscnt  = 0
var float condhigh = na
var float condlow  = na
float H_ = ta.highest(high, conslen)
float L_ = ta.lowest(low,  conslen)
var line upline = na
var line dnline = na

ppChanged = ta.change(pp) != 0

if ppChanged
    if conscnt > 0 and pp <= condhigh and pp >= condlow
        conscnt += 1
    else
        conscnt := 0
else
    conscnt += 1

if conscnt >= conslen
    if conscnt == conslen
        condhigh := H_
        condlow  := L_
    else
        line.delete(upline)
        line.delete(dnline)
        condhigh := math.max(condhigh, high)
        condlow  := math.min(condlow, low)
    upline := line.new(bar_index, condhigh, bar_index - conscnt, condhigh, color = color.red,  style = line.style_dashed)
    dnline := line.new(bar_index, condlow,  bar_index - conscnt, condlow,  color = color.lime, style = line.style_dashed)

pCondHigh = plot(condhigh, color = color.new(color.white, 100), style = plot.style_stepline)
pCondLow  = plot(condlow,  color = color.new(color.white, 100), style = plot.style_stepline)
fill(pCondHigh, pCondLow, color = paintcons and conscnt > conslen ? zonecol : color.new(color.white, 100))

inConsolidation = conscnt >= conslen

//===============================================================
// 7) RSI DIVERGENCE
//===============================================================
groupDiv = "RSI Divergence Filters"

calcDivergence   = input.bool(false, "Calculate RSI Divergence", group=groupDiv,
                      tooltip = "Enable for divergence-based entry confirmation.")
useBullDivForBuy = input.bool(false, "Require Bullish RSI Divergence for BUY", group=groupDiv)
useBearDivForSell= input.bool(false, "Require Bearish RSI Divergence for SELL", group=groupDiv)

divLookbackRight = 5
divLookbackLeft  = 5
divRangeUpper    = 60
divRangeLower    = 5

_inRange(cond) =>
    bs = ta.barssince(cond)
    not na(bs) and (divRangeLower <= bs and bs <= divRangeUpper)

var bool plFound = false
var bool phFound = false
var bool bullCond = false
var bool bearCond = false

rsiLBR = rsi[divLookbackRight]

if calcDivergence
    plPivot = ta.pivotlow(rsi, divLookbackLeft, divLookbackRight)
    phPivot = ta.pivothigh(rsi, divLookbackLeft, divLookbackRight)
    plFound := not na(plPivot)
    phFound := not na(phPivot)

    plInRange = _inRange(plFound[1])
    phInRange = _inRange(phFound[1])

    rsiHL   = rsiLBR > ta.valuewhen(plFound, rsiLBR, 1) and plInRange
    lowLBR  = low[divLookbackRight]
    priceLL = lowLBR < ta.valuewhen(plFound, lowLBR, 1)
    bullCond := priceLL and rsiHL and plFound

    rsiLH   = rsiLBR < ta.valuewhen(phFound, rsiLBR, 1) and phInRange
    highLBR = high[divLookbackRight]
    priceHH = highLBR > ta.valuewhen(phFound, highLBR, 1)
    bearCond := priceHH and rsiLH and phFound
else
    plFound  := false
    phFound  := false
    bullCond := false
    bearCond := false

bullDivOk = not useBullDivForBuy  or bullCond
bearDivOk = not useBearDivForSell or bearCond

alertcondition(bullCond, title='RSI Regular Bullish Divergence', message="RSI Regular Bullish Divergence detected.")
alertcondition(bearCond, title='RSI Regular Bearish Divergence', message="RSI Regular Bearish Divergence detected.")

//===============================================================
// 8) BUY / SELL ENTRY ENGINE
//
// Three entry quality levels:
//
// "BUY+" / "SELL+" (Premium):
//   Sweep + BOS + Price retests the sweep zone + Confirmation candle
//   Highest quality — pullback into the zone after structure break
//
// "BUY" / "SELL" (Standard):
//   Sweep + BOS both happened recently (within setup window)
//   Confirmation candle — no retest required
//   Catches trending moves where retest never happens
//
// "BUY" / "SELL" (BOS-only):
//   BOS confirmed recently + mini pullback (at least 1 counter candle in last 3 bars)
//   No sweep required — catches moves where equal highs/lows didn't form
//   Most frequent signal type on M5
//
// All require: RSI filter, CZ filter (if on), HTF bias, EMA momentum
//===============================================================
grpEntry = "Entry Engine"
entryEnabled    = input.bool(true,  "Enable BUY/SELL Labels", group=grpEntry)
entryUseBOS     = input.bool(true,  "Allow BOS-only entries (no sweep needed)", group=grpEntry,
                    tooltip="If ON, a confirmed BOS + pullback + confirmation is enough for entry. More signals but slightly lower quality.")
entryRequireMom = input.bool(true,  "Require EMA Momentum Alignment", group=grpEntry)
entryRSIOBLevel = input.float(70.0, "RSI Overbought (block BUY above)", step=1.0, group=grpEntry)
entryRSIOSLevel = input.float(30.0, "RSI Oversold (block SELL below)", step=1.0, group=grpEntry)
entryCooldown   = input.int(10, "Min bars between same-direction signals", minval=1, group=grpEntry)

// Track recent BOS events (within setup window)
var int   lastBosUpBar   = na
var int   lastBosDownBar = na

if poBosUpConfirmed
    lastBosUpBar := bar_index
if poBosDownConfirmed
    lastBosDownBar := bar_index

bosUpRecent   = not na(lastBosUpBar)   and (bar_index - lastBosUpBar)   <= poSetupWindow
bosDownRecent = not na(lastBosDownBar) and (bar_index - lastBosDownBar) <= poSetupWindow

// Candle confirmation (relaxed body ratio for M5 wicky candles)
bullishCandle = close > open and (close - open) > (high - low) * 0.2
bearishCandle = close < open and (open - close) > (high - low) * 0.2

// Mini pullback detection (at least 1 counter-candle in last 5 bars — not chasing)
// On strong 1H trends, 3-bar window often has zero pullback candles, so use 5
hadRedCandle   = close[1] < open[1] or close[2] < open[2] or close[3] < open[3] or close[4] < open[4] or close[5] < open[5]
hadGreenCandle = close[1] > open[1] or close[2] > open[2] or close[3] > open[3] or close[4] > open[4] or close[5] > open[5]

// Anti-spam cooldown
var int lastBuyBar  = na
var int lastSellBar = na
buyCooldownOk  = na(lastBuyBar)  or (bar_index - lastBuyBar)  >= entryCooldown
sellCooldownOk = na(lastSellBar) or (bar_index - lastSellBar) >= entryCooldown

// === SHARED FILTERS (apply to all tiers) ===
buyTrend       = not useTrendEMA or trendUp
buyMomentum    = not entryRequireMom or momBull
buyRSI         = rsi < entryRSIOBLevel
buyNotInCZ     = not useCZFilter or not inConsolidation
buyDivOk       = bullDivOk
buyConfirmBar  = bullishCandle
buyHTF         = not poUseHTF or poHTFBull

sellTrend       = not useTrendEMA or trendDown
sellMomentum    = not entryRequireMom or momBear
sellRSI         = rsi > entryRSIOSLevel
sellNotInCZ     = not useCZFilter or not inConsolidation
sellDivOk       = bearDivOk
sellConfirmBar  = bearishCandle
sellHTF         = not poUseHTF or poHTFBear

buyFiltersOk  = buyTrend and buyMomentum and buyRSI and buyNotInCZ and buyDivOk and buyConfirmBar and buyHTF and buyCooldownOk
sellFiltersOk = sellTrend and sellMomentum and sellRSI and sellNotInCZ and sellDivOk and sellConfirmBar and sellHTF and sellCooldownOk

// === TIER 1: PREMIUM ENTRY (sweep + BOS + retest zone) ===
buyContextPremium  = poRetestLong and bosUpRecent
sellContextPremium = poRetestShort and bosDownRecent

buyPremium  = entryEnabled and poEnabled and buyContextPremium and buyFiltersOk
sellPremium = entryEnabled and poEnabled and sellContextPremium and sellFiltersOk

// === TIER 2: STANDARD ENTRY (sweep + BOS recent, no retest) ===
buyContextStandard  = sweepDownRecent and bosUpRecent
sellContextStandard = sweepUpRecent and bosDownRecent

buyStandard  = entryEnabled and poEnabled and not buyPremium and buyContextStandard and buyFiltersOk
sellStandard = entryEnabled and poEnabled and not sellPremium and sellContextStandard and sellFiltersOk

// === TIER 3: BOS-ONLY ENTRY (no sweep needed, requires pullback) ===
buyContextBOS  = bosUpRecent and hadRedCandle
sellContextBOS = bosDownRecent and hadGreenCandle

buyBOSOnly  = entryEnabled and entryUseBOS and not buyPremium and not buyStandard and buyContextBOS and buyFiltersOk
sellBOSOnly = entryEnabled and entryUseBOS and not sellPremium and not sellStandard and sellContextBOS and sellFiltersOk

// Combined signals
buySignal  = buyPremium or buyStandard or buyBOSOnly
sellSignal = sellPremium or sellStandard or sellBOSOnly

// Fire signals and consume the setup
if buySignal
    lastBuyBar := bar_index
    // Consume sweep/BOS so setup doesn't fire again
    if buyPremium or buyStandard
        poSweepDownBar := na
        poLongSetupBar := na
        poLongZoneLow  := na
        poLongZoneHigh := na
    if buyBOSOnly
        lastBosUpBar := na
    sigLabel = buyPremium ? "BUY+" : "BUY"
    sigColor = buyPremium ? color.new(#00E676, 0) : color.new(#00C853, 0)
    label.new(bar_index, low, sigLabel,
        style=label.style_label_up,
        color=sigColor,
        textcolor=color.white,
        size=size.normal)

if sellSignal
    lastSellBar := bar_index
    if sellPremium or sellStandard
        poSweepUpBar    := na
        poShortSetupBar := na
        poShortZoneLow  := na
        poShortZoneHigh := na
    if sellBOSOnly
        lastBosDownBar := na
    sigLabelS = sellPremium ? "SELL+" : "SELL"
    sigColorS = sellPremium ? color.new(#FF1744, 0) : color.new(#FF5252, 0)
    label.new(bar_index, high, sigLabelS,
        style=label.style_label_down,
        color=sigColorS,
        textcolor=color.white,
        size=size.normal)

// === ALERTS ===
alertcondition(buySignal,  title="Wizkid BUY Signal",  message="Wizkid v8: BUY signal on XAUUSD")
alertcondition(sellSignal, title="Wizkid SELL Signal", message="Wizkid v8: SELL signal on XAUUSD")
alertcondition(buyPremium,  title="Wizkid BUY+ Premium",  message="Wizkid v8: BUY+ premium entry (retest) on XAUUSD")
alertcondition(sellPremium, title="Wizkid SELL+ Premium", message="Wizkid v8: SELL+ premium entry (retest) on XAUUSD")

//===============================================================
// 9) TP EXIT HINTS (optional)
//
// Shows a small TP label when an open signal reaches a profit
// target based on ATR, or when RSI hits overbought/oversold.
//===============================================================
grpTP = "Take Profit Hints"
showTPHints   = input.bool(true,  "Show TP Hints", group=grpTP)
tpATRMult     = input.float(2.0,  "TP Distance (x ATR)", step=0.5, group=grpTP)
tpRSIExit     = input.float(72.0, "RSI level to suggest TP (longs)", step=1.0, group=grpTP)
tpRSIExitSell = input.float(28.0, "RSI level to suggest TP (shorts)", step=1.0, group=grpTP)

var float buyEntryPrice  = na
var float sellEntryPrice = na
var bool  buyTPFired     = false
var bool  sellTPFired    = false

if buySignal
    buyEntryPrice := close
    buyTPFired    := false
if sellSignal
    sellEntryPrice := close
    sellTPFired    := false

// Long TP
buyTPTarget = not na(buyEntryPrice) ? buyEntryPrice + poAtr * tpATRMult : na
buyTPHit    = not na(buyEntryPrice) and not buyTPFired and
     (high >= buyTPTarget or rsi >= tpRSIExit)

if showTPHints and buyTPHit
    buyTPFired := true
    tpReason = rsi >= tpRSIExit ? "TP (RSI)" : "TP (Target)"
    label.new(bar_index, high, tpReason,
        style=label.style_label_down,
        color=color.new(color.yellow, 0),
        textcolor=color.black,
        size=size.small)

// Short TP
sellTPTarget = not na(sellEntryPrice) ? sellEntryPrice - poAtr * tpATRMult : na
sellTPHit    = not na(sellEntryPrice) and not sellTPFired and
     (low <= sellTPTarget or rsi <= tpRSIExitSell)

if showTPHints and sellTPHit
    sellTPFired := true
    tpReasonS = rsi <= tpRSIExitSell ? "TP (RSI)" : "TP (Target)"
    label.new(bar_index, low, tpReasonS,
        style=label.style_label_up,
        color=color.new(color.orange, 0),
        textcolor=color.black,
        size=size.small)
